# Copy these into your shell or a local .env file before starting LiteLLM.
# Do not use your ChatGPT email/password here. Use an OpenAI API key.
OPENAI_API_KEY=sk-your-openai-api-key

# Client apps will use this key when calling the local LiteLLM proxy.
LITELLM_MASTER_KEY=sk-local-litellm-dev-key

# Defaults used by scripts/start_litellm_proxy.sh
LITELLM_HOST=0.0.0.0
LITELLM_PORT=4500
